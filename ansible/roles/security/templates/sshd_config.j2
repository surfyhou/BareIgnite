# sshd_config -- OpenSSH server configuration
# Generated by BareIgnite post-install
# {{ ansible_managed }}

# --- Network ---

Port {{ security_ssh_port }}
AddressFamily any
ListenAddress 0.0.0.0
ListenAddress ::

# --- Authentication ---

PermitRootLogin {{ security_ssh_permit_root_login }}
MaxAuthTries {{ security_ssh_max_auth_tries }}
PubkeyAuthentication yes
PasswordAuthentication {{ 'yes' if security_ssh_password_auth else 'no' }}
PermitEmptyPasswords no
ChallengeResponseAuthentication no

# --- Key exchange and ciphers (modern defaults) ---

# Use strong key exchange algorithms
KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,ecdh-sha2-nistp256,ecdh-sha2-nistp384,ecdh-sha2-nistp521,diffie-hellman-group-exchange-sha256

# Use strong ciphers
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com,aes256-ctr,aes192-ctr,aes128-ctr

# Use strong MACs
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,hmac-sha2-512,hmac-sha2-256

# --- Session ---

X11Forwarding {{ 'yes' if security_ssh_x11_forwarding else 'no' }}
PrintMotd yes
PrintLastLog yes
TCPKeepAlive yes
ClientAliveInterval {{ security_ssh_client_alive_interval }}
ClientAliveCountMax {{ security_ssh_client_alive_count_max }}
UseDNS no

# --- Logging ---

SyslogFacility AUTH
LogLevel INFO

# --- Subsystems ---

Subsystem sftp /usr/libexec/openssh/sftp-server

{% if security_ssh_allowed_users | length > 0 %}
# --- Access control ---

AllowUsers {{ security_ssh_allowed_users | join(' ') }}
{% endif %}

# --- Security ---

# Disable unused authentication methods
GSSAPIAuthentication no
KerberosAuthentication no
HostbasedAuthentication no
IgnoreRhosts yes

# Limit login grace time
LoginGraceTime 60

# Restrict to protocol 2
Protocol 2

# Banner
Banner none

# Maximum sessions
MaxSessions 10
MaxStartups 10:30:60
