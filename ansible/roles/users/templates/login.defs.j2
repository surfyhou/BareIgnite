# /etc/login.defs -- Password aging and login configuration
# Generated by BareIgnite post-install
# {{ ansible_managed }}

# Password aging controls
PASS_MAX_DAYS   {{ users_password_max_days }}
PASS_MIN_DAYS   {{ users_password_min_days }}
PASS_MIN_LEN    {{ users_password_min_length | default(8) }}
PASS_WARN_AGE   {{ users_password_warn_days }}

# User/group ID ranges
UID_MIN                  1000
UID_MAX                 60000
SYS_UID_MIN               201
SYS_UID_MAX               999
GID_MIN                  1000
GID_MAX                 60000
SYS_GID_MIN               201
SYS_GID_MAX               999

# Home directory creation
CREATE_HOME     yes
UMASK           {{ base_umask | default('022') }}

# Encryption method for passwords
ENCRYPT_METHOD SHA512

# Login log
LOG_OK_LOGINS   yes
