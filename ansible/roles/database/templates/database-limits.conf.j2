# /etc/security/limits.d/99-bareignite-database.conf
# Database user ulimit configuration
# Generated by BareIgnite post-install
# {{ ansible_managed }}

{{ database_user }}  soft  nofile    {{ database_ulimit_nofile }}
{{ database_user }}  hard  nofile    {{ database_ulimit_nofile }}
{{ database_user }}  soft  nproc     {{ database_ulimit_nproc }}
{{ database_user }}  hard  nproc     {{ database_ulimit_nproc }}
{{ database_user }}  soft  memlock   {{ database_ulimit_memlock }}
{{ database_user }}  hard  memlock   {{ database_ulimit_memlock }}
{{ database_user }}  soft  stack     {{ database_ulimit_stack }}
{{ database_user }}  hard  stack     {{ database_ulimit_stack }}
{{ database_user }}  soft  core      {{ database_ulimit_core }}
{{ database_user }}  hard  core      {{ database_ulimit_core }}
