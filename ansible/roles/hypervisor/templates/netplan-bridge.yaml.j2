# netplan-bridge.yaml -- Ubuntu netplan bridge configuration for KVM
# Generated by BareIgnite post-install
# {{ ansible_managed }}
network:
  version: 2
  renderer: networkd

{% if hypervisor_bridge_slave %}
  ethernets:
    {{ hypervisor_bridge_slave }}:
      dhcp4: false
      dhcp6: false
{% endif %}

  bridges:
    {{ hypervisor_bridge_name }}:
{% if hypervisor_bridge_slave %}
      interfaces:
        - {{ hypervisor_bridge_slave }}
{% endif %}
{% if hypervisor_bridge_ip %}
      addresses:
        - {{ hypervisor_bridge_ip }}/{{ hypervisor_bridge_prefix }}
{% if hypervisor_bridge_gateway %}
      routes:
        - to: default
          via: {{ hypervisor_bridge_gateway }}
{% endif %}
{% else %}
      dhcp4: true
{% endif %}
      parameters:
        stp: true
        forward-delay: 0
