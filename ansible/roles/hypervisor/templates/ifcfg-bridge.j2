# ifcfg-bridge -- Bridge interface configuration for KVM
# Generated by BareIgnite post-install
# {{ ansible_managed }}
TYPE=Bridge
NAME={{ hypervisor_bridge_name }}
DEVICE={{ hypervisor_bridge_name }}
ONBOOT=yes
DELAY=0
STP=yes
{% if hypervisor_bridge_ip %}
BOOTPROTO=none
IPADDR={{ hypervisor_bridge_ip }}
PREFIX={{ hypervisor_bridge_prefix }}
{% if hypervisor_bridge_gateway %}
GATEWAY={{ hypervisor_bridge_gateway }}
{% endif %}
{% else %}
BOOTPROTO=dhcp
{% endif %}
