# ifcfg-bond -- Bond master interface configuration
# Generated by BareIgnite post-install
# {{ ansible_managed }}
TYPE=Bond
BONDING_MASTER=yes
NAME={{ bond_name }}
DEVICE={{ bond_name }}
ONBOOT=yes
BOOTPROTO=none
IPADDR={{ ip_address }}
PREFIX={{ prefix }}
{% if gateway %}
GATEWAY={{ gateway }}
{% endif %}
{% if dns1 %}
DNS1={{ dns1 }}
{% endif %}
BONDING_OPTS="mode={{ bond_mode | default('802.3ad') }} miimon=100"
