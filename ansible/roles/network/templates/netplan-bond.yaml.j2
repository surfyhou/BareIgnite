# netplan-bond.yaml -- Ubuntu netplan bonding configuration
# Generated by BareIgnite post-install
# {{ ansible_managed }}
network:
  version: 2
  renderer: networkd

  ethernets:
{% for slave in bond.slaves %}
    {{ slave }}:
      dhcp4: false
      dhcp6: false
{% endfor %}

  bonds:
    {{ bond.name }}:
      interfaces:
{% for slave in bond.slaves %}
        - {{ slave }}
{% endfor %}
      addresses:
        - {{ bond.ip }}/{{ bond.prefix | default(24) }}
{% if bond.gateway is defined and bond.gateway %}
      routes:
        - to: default
          via: {{ bond.gateway }}
{% endif %}
{% if bond.dns is defined and bond.dns | length > 0 %}
      nameservers:
        addresses:
{% for dns in bond.dns %}
          - {{ dns }}
{% endfor %}
{% endif %}
      parameters:
        mode: {{ bond.mode | default('802.3ad') }}
        mii-monitor-interval: 100
{% if bond.mode | default('802.3ad') == '802.3ad' %}
        lacp-rate: fast
        transmit-hash-policy: layer3+4
{% endif %}
