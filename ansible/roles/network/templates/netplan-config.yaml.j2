# netplan-config.yaml -- Ubuntu netplan data network configuration
# Generated by BareIgnite post-install
# {{ ansible_managed }}
network:
  version: 2
  renderer: networkd

{% if network_data_nics | length > 0 or network_bonds | length > 0 %}
  ethernets:
{% for nic in network_data_nics %}
{% if nic.mode | default('static') == 'dhcp' %}
    {{ nic.device | default(nic.name) }}:
      dhcp4: true
      dhcp6: false
{% else %}
    {{ nic.device | default(nic.name) }}:
      dhcp4: false
      dhcp6: false
      addresses:
        - {{ nic.ip }}/{{ nic.prefix | default(24) }}
{% if nic.gateway is defined and nic.gateway %}
      routes:
        - to: default
          via: {{ nic.gateway }}
{% endif %}
{% if nic.dns is defined and nic.dns | length > 0 %}
      nameservers:
        addresses:
{% for dns in nic.dns %}
          - {{ dns }}
{% endfor %}
{% endif %}
{% if nic.mac is defined and nic.mac %}
      match:
        macaddress: "{{ nic.mac | lower }}"
{% endif %}
{% endif %}
{% endfor %}
{# Slaves for bonds need to be listed as ethernets with no config #}
{% for bond in network_bonds %}
{% for slave in bond.slaves %}
    {{ slave }}:
      dhcp4: false
      dhcp6: false
{% endfor %}
{% endfor %}
{% endif %}

{% if network_bonds | length > 0 %}
  bonds:
{% for bond in network_bonds %}
    {{ bond.name }}:
      interfaces:
{% for slave in bond.slaves %}
        - {{ slave }}
{% endfor %}
      addresses:
        - {{ bond.ip }}/{{ bond.prefix | default(24) }}
{% if bond.gateway is defined and bond.gateway %}
      routes:
        - to: default
          via: {{ bond.gateway }}
{% endif %}
{% if bond.dns is defined and bond.dns | length > 0 %}
      nameservers:
        addresses:
{% for dns in bond.dns %}
          - {{ dns }}
{% endfor %}
{% endif %}
      parameters:
        mode: {{ bond.mode | default('802.3ad') }}
        mii-monitor-interval: 100
{% if bond.mode | default('802.3ad') == '802.3ad' %}
        lacp-rate: fast
        transmit-hash-policy: layer3+4
{% endif %}
{% endfor %}
{% endif %}

{% if network_vlans | length > 0 %}
  vlans:
{% for vlan in network_vlans %}
    {{ vlan.parent }}.{{ vlan.id }}:
      id: {{ vlan.id }}
      link: {{ vlan.parent }}
{% if vlan.ip is defined and vlan.ip %}
      addresses:
        - {{ vlan.ip }}/{{ vlan.prefix | default(24) }}
{% if vlan.gateway is defined and vlan.gateway %}
      routes:
        - to: default
          via: {{ vlan.gateway }}
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
