# ifcfg-vlan -- VLAN interface configuration
# Generated by BareIgnite post-install
# {{ ansible_managed }}
VLAN=yes
TYPE=Vlan
NAME={{ vlan_parent }}.{{ vlan_id }}
DEVICE={{ vlan_parent }}.{{ vlan_id }}
PHYSDEV={{ vlan_parent }}
VLAN_ID={{ vlan_id }}
ONBOOT=yes
{% if ip_address %}
BOOTPROTO=none
IPADDR={{ ip_address }}
PREFIX={{ prefix }}
{% if gateway %}
GATEWAY={{ gateway }}
{% endif %}
{% else %}
BOOTPROTO=none
{% endif %}
