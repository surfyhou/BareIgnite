# ifcfg-static -- Static IP interface configuration
# Generated by BareIgnite post-install
# {{ ansible_managed }}
TYPE=Ethernet
NAME={{ nic_name }}
DEVICE={{ nic_device }}
ONBOOT=yes
{% if boot_proto == 'dhcp' %}
BOOTPROTO=dhcp
{% else %}
BOOTPROTO=none
IPADDR={{ ip_address }}
PREFIX={{ prefix }}
{% if gateway %}
GATEWAY={{ gateway }}
{% endif %}
{% if dns1 %}
DNS1={{ dns1 }}
{% endif %}
{% endif %}
{% if nic_mac %}
HWADDR={{ nic_mac }}
{% endif %}
