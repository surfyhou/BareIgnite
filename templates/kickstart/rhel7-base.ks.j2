#version=RHEL7
# RHEL 7 / CentOS 7 Kickstart Configuration
# Generated by BareIgnite for {{ hostname }}
# Compatible with: CentOS 7, RHEL 7, older NeoKylin (RHEL7-based)

# --- Installation method ---
# Install from HTTP repository served by BareIgnite control node
url --url="http://{{ control_ip }}/images/{{ os_id | replace('centos', 'centos/') | replace('rhel', 'rhel/') }}/{{ arch }}/"

# Use text mode installer (no GUI required)
text

# Accept EULA
eula --agreed

# --- Locale and keyboard ---
lang {{ locale | default('en_US.UTF-8') }}
keyboard --vckeymap=us --xlayouts='us'
timezone {{ timezone | default('UTC') }} --isUtc

# --- Network configuration ---
# During installation: DHCP on PXE NIC
network --bootproto=dhcp --device={{ pxe_mac }} --activate --onboot=yes
network --hostname={{ hostname }}

# --- Authentication ---
# Root password (hashed)
rootpw --iscrypted {{ root_password }}

# Use authconfig (RHEL7 -- authselect is not available)
authconfig --enableshadow --passalgo=sha512

# SELinux
selinux --enforcing

# Firewall
firewall --enabled --service=ssh

# --- Boot and disk ---
# Bootloader configuration
bootloader --location=mbr --append="crashkernel=auto"

# Clear all existing partitions
clearpart --all --initlabel

{% if partition_scheme is defined and partition_scheme == 'custom' and custom_disk_layout is defined %}
# Custom partition layout from spec
{% for part in custom_disk_layout %}
{% if part.fstype == 'swap' %}
{% if part.vg is defined %}
logvol swap --vgname={{ part.vg }} --name={{ part.lv | default('lv_swap') }} --size={{ part.size | replace('G', '000') | replace('M', '') }}
{% else %}
part swap --size={{ part.size | replace('G', '000') | replace('M', '') }}
{% endif %}
{% elif part.mount == '/boot' %}
part /boot --fstype={{ part.fstype | default('xfs') }} --size={{ part.size | replace('G', '000') | replace('M', '') }}
{% elif part.mount == '/boot/efi' %}
part /boot/efi --fstype=efi --size={{ part.size | replace('G', '000') | replace('M', '') }}
{% elif part.vg is defined %}
{% if loop.first or part.mount == '/' %}
part pv.01 --size=1 --grow
volgroup {{ part.vg }} pv.01
{% endif %}
{% if part.size == '100%FREE' %}
logvol {{ part.mount }} --vgname={{ part.vg }} --name={{ part.lv | default('lv_' + part.mount | replace('/', '_')) }} --fstype={{ part.fstype | default('xfs') }} --size=1 --grow
{% else %}
logvol {{ part.mount }} --vgname={{ part.vg }} --name={{ part.lv | default('lv_' + part.mount | replace('/', '_')) }} --fstype={{ part.fstype | default('xfs') }} --size={{ part.size | replace('G', '000') | replace('M', '') }}
{% endif %}
{% else %}
{% if part.size == '100%FREE' %}
part {{ part.mount }} --fstype={{ part.fstype | default('xfs') }} --size=1 --grow
{% else %}
part {{ part.mount }} --fstype={{ part.fstype | default('xfs') }} --size={{ part.size | replace('G', '000') | replace('M', '') }}
{% endif %}
{% endif %}
{% endfor %}
{% elif partition_scheme is defined and partition_scheme == 'database' %}
# Database server partition layout -- large /var and /data
part /boot --fstype=xfs --size=1024
part /boot/efi --fstype=efi --size=512
part pv.01 --size=1 --grow
volgroup vg_root pv.01
logvol /     --vgname=vg_root --name=lv_root  --fstype=xfs --size=51200
logvol /var  --vgname=vg_root --name=lv_var   --fstype=xfs --size=51200
logvol /data --vgname=vg_root --name=lv_data  --fstype=xfs --size=1 --grow
logvol swap  --vgname=vg_root --name=lv_swap  --size=16384
{% elif partition_scheme is defined and partition_scheme == 'appserver' %}
# Application server partition layout
part /boot --fstype=xfs --size=1024
part /boot/efi --fstype=efi --size=512
part pv.01 --size=1 --grow
volgroup vg_root pv.01
logvol /     --vgname=vg_root --name=lv_root  --fstype=xfs --size=51200
logvol /var  --vgname=vg_root --name=lv_var   --fstype=xfs --size=20480
logvol /opt  --vgname=vg_root --name=lv_opt   --fstype=xfs --size=1 --grow
logvol swap  --vgname=vg_root --name=lv_swap  --size=8192
{% elif partition_scheme is defined and partition_scheme == 'storage' %}
# Storage server partition layout -- minimal root, large data
part /boot --fstype=xfs --size=1024
part /boot/efi --fstype=efi --size=512
part pv.01 --size=1 --grow
volgroup vg_root pv.01
logvol /     --vgname=vg_root --name=lv_root  --fstype=xfs --size=30720
logvol /data --vgname=vg_root --name=lv_data  --fstype=xfs --size=1 --grow
logvol swap  --vgname=vg_root --name=lv_swap  --size=8192
{% else %}
# Generic partition layout (default)
part /boot --fstype=xfs --size=1024
part /boot/efi --fstype=efi --size=512
part pv.01 --size=1 --grow
volgroup vg_root pv.01
logvol /     --vgname=vg_root --name=lv_root  --fstype=xfs --size=51200
logvol /var  --vgname=vg_root --name=lv_var   --fstype=xfs --size=20480
logvol /home --vgname=vg_root --name=lv_home  --fstype=xfs --size=1 --grow
logvol swap  --vgname=vg_root --name=lv_swap  --size=8192
{% endif %}

# Do not configure X Window System
skipx

# --- Package selection ---
# CentOS 7 / RHEL 7 uses @base and @core groups
%packages
@base
@core
curl
wget
python
openssh-server
openssh-clients
vim-enhanced
net-tools
bash-completion
tar
gzip
bzip2
yum-utils
{% if ntp_use_chrony | default(true) %}
chrony
{% else %}
ntp
ntpdate
{% endif %}
{% if extra_packages is defined %}
{% for pkg in extra_packages %}
{{ pkg }}
{% endfor %}
{% endif %}
%end

# --- Pre-install script ---
%pre --log=/tmp/bareignite-pre.log
# Log PXE boot information
echo "BareIgnite pre-install for {{ hostname }}"
echo "Date: $(date)"
echo "MAC: {{ pxe_mac }}"
%end

# --- Post-install script ---
%post --log=/root/bareignite-postinstall.log

echo "=== BareIgnite post-install script started at $(date) ==="

# --- SSH key injection ---
mkdir -p /root/.ssh && chmod 700 /root/.ssh
{% if ssh_keys is defined %}
{% for key in ssh_keys %}
echo "{{ key }}" >> /root/.ssh/authorized_keys
{% endfor %}
chmod 600 /root/.ssh/authorized_keys
{% endif %}

# --- Permit root login via SSH ---
sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config

# --- Configure time synchronization ---
{% if ntp_servers is defined and ntp_servers | length > 0 %}
{% if ntp_use_chrony | default(true) %}
# CentOS 7 supports chrony (preferred) or ntp
cat > /etc/chrony.conf <<'CHRONYEOF'
{% for ntp_srv in ntp_servers %}
server {{ ntp_srv }} iburst
{% endfor %}
driftfile /var/lib/chrony/drift
makestep 1.0 3
rtcsync
logdir /var/log/chrony
CHRONYEOF
systemctl enable chronyd
systemctl disable ntpd 2>/dev/null || true
{% else %}
# Legacy NTP daemon configuration
cat > /etc/ntp.conf <<'NTPEOF'
driftfile /var/lib/ntp/drift
restrict default nomodify notrap nopeer noquery
restrict 127.0.0.1
restrict ::1
{% for ntp_srv in ntp_servers %}
server {{ ntp_srv }} iburst
{% endfor %}
NTPEOF
systemctl enable ntpd
systemctl disable chronyd 2>/dev/null || true
{% endif %}
{% endif %}

# --- Configure DNS resolvers ---
{% if nameservers is defined and nameservers | length > 0 %}
cat > /etc/resolv.conf <<'DNSEOF'
{% for ns in nameservers %}
nameserver {{ ns }}
{% endfor %}
DNSEOF
{% endif %}

# --- Enable essential services ---
systemctl enable sshd

echo "=== BareIgnite post-install script finished at $(date) ==="

# --- Signal completion to BareIgnite control node ---
curl -s "http://{{ control_ip }}:{{ callback_port }}/callback?server={{ hostname }}&status=success" || true

%end

# Reboot after installation
reboot
