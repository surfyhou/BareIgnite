# ESXi 7 Kickstart Configuration
# Generated by BareIgnite for {{ hostname }}
# VMware ESXi 7.x automated installation

# Accept the VMware license agreement
vmaccepteula

# Set root password (plaintext -- ESXi hashes it during install)
rootpw {{ root_password }}

# Install on {{ install_disk | default('firstdisk') }}
{% if install_disk is defined and install_disk != 'firstdisk' %}
install --disk={{ install_disk }} --overwritevmfs
{% else %}
install --firstdisk --overwritevmfs
{% endif %}

# Network configuration during installation
{% if static_ip is defined and static_ip %}
network --bootproto=static --ip={{ static_ip }} --netmask={{ netmask }} --gateway={{ gateway }} --hostname={{ hostname }}{% if nameservers is defined and nameservers | length > 0 %} --nameserver={{ nameservers | join(',') }}{% endif %}

{% else %}
network --bootproto=dhcp --device={{ pxe_mac }}
{% endif %}

{% if vlan is defined and vlan and vlan != 'null' and vlan != '' %}
# VLAN tagging for management network
esxcli network vswitch standard portgroup set -p "Management Network" --vlan-id {{ vlan }}
{% endif %}

# Reboot after installation completes
reboot

# ============================================================================
# %firstboot -- Runs on the first boot after ESXi installation
# Uses busybox shell (ESXi does not have bash)
# ============================================================================
%firstboot --interpreter=busybox

# Enable and start SSH service
vim-cmd hostsvc/enable_ssh
vim-cmd hostsvc/start_ssh

# Enable and start ESXi Shell
vim-cmd hostsvc/enable_esx_shell
vim-cmd hostsvc/start_esx_shell

# Set the fully qualified hostname
esxcli system hostname set --fqdn={{ hostname }}

{% if static_ip is defined and static_ip %}
# Configure management network with static IP
esxcli network ip interface ipv4 set -i vmk0 -I {{ static_ip }} -N {{ netmask }} -t static
{% if gateway is defined and gateway and gateway != 'null' %}
esxcli network ip route ipv4 add -n default -g {{ gateway }}
{% endif %}
{% endif %}

{% if nameservers is defined and nameservers | length > 0 %}
# Configure DNS
{% for ns in nameservers %}
esxcli network ip dns server add --server={{ ns }}
{% endfor %}
{% endif %}

# Suppress ESXi Shell warning in DCUI
esxcli system settings advanced set -o /UserVars/SuppressShellWarning -i 1

# Enable NTP if servers are configured
# Note: ESXi 7 uses the same NTP configuration as ESXi 8
{% if ntp_servers is defined and ntp_servers | length > 0 %}
cat > /etc/ntp.conf <<'NTPEOF'
restrict default kod nomodify notrap noquerynopeer
restrict 127.0.0.1
{% for ntp_srv in ntp_servers %}
server {{ ntp_srv }}
{% endfor %}
driftfile /etc/ntp.drift
NTPEOF
/etc/init.d/ntpd restart
{% endif %}

# Signal completion to BareIgnite control node
wget -O /dev/null "http://{{ control_ip }}:{{ callback_port }}/callback?server={{ hostname }}&status=success" 2>/dev/null || true
